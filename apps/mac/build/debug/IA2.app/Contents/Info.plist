<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Identity. Product, target, and executable all share the
         name "IA2" now (the SwiftPM target was renamed from the
         legacy "ControlSoftware" in the same rename pass). -->
    <key>CFBundleName</key>
    <string>IA2</string>
    <key>CFBundleDisplayName</key>
    <string>IA2</string>
    <key>CFBundleIdentifier</key>
    <string>com.supcon.ia2</string>
    <key>CFBundleExecutable</key>
    <string>IA2</string>
    <!-- Icon. The file lives at Contents/Resources/AppIcon.icns;
         this key references it without the extension (macOS
         convention). Generated by apps/mac/Resources/make-icon.swift
         + iconutil during build.sh — keep them in sync. -->
    <key>CFBundleIconFile</key>
    <string>AppIcon</string>
    <key>CFBundleVersion</key>
    <string>0.0.1</string>
    <key>CFBundleShortVersionString</key>
    <string>0.0.1</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleSignature</key>
    <string>????</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>

    <!-- Platform requirements -->
    <key>LSMinimumSystemVersion</key>
    <string>13.0</string>
    <key>NSHumanReadableCopyright</key>
    <string>Copyright © 2026 supcon international. IA2 is licensed under Apache-2.0.</string>

    <!-- High-DPI / Retina -->
    <key>NSHighResolutionCapable</key>
    <true/>

    <!--
        Hardened Runtime + sandbox concerns:
        - We do NOT enable App Sandbox (would block child process spawn
          and arbitrary filesystem read for project loading).
        - Hardened Runtime IS enabled at sign-time via build.sh; this
          file just declares the exceptions the child needs.
        - JIT not required (no Wasm / V8 inside the shell).
    -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <!--
            The shell loads the bundled axum server over plain http on
            127.0.0.1 — no TLS, deliberately. ATS would block this by
            default; allow exceptions only for loopback.
        -->
        <key>NSAllowsLocalNetworking</key>
        <true/>
    </dict>

    <!-- No automatic dark/light blending; let the React app handle it. -->
    <key>NSRequiresAquaSystemAppearance</key>
    <false/>
</dict>
</plist>
